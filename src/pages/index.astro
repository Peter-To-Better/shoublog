---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import Pagination from '../components/Pagination.astro';
import { getExcerpt } from '../utils/helpers';

const POSTS_PER_PAGE = 9;

const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <!-- Hero -->
    <section class="text-center mb-14">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white mb-3">
        peter-to-better
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400">
        一個變好變強的部落格 — 技術分享與成長的天地
      </p>
    </section>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          pubDate={post.data.pubDate}
          category={post.data.category}
          tags={post.data.tags}
          description={post.data.description || getExcerpt(post.body)}
          slug={post.slug}
          body={post.body}
        />
      ))}
    </div>

    <Pagination currentPage={1} totalPages={totalPages} />
  </div>
</BaseLayout>
